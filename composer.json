{
  "name": "maccesar/laravel-glide-enhanced",
  "description": "Enhanced dynamic image processing for Laravel using Glide",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "MacCesar\\LaravelGlideEnhanced\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MacCesar\\LaravelGlideEnhanced\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "César Estrada"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": "^8.2",
    "illuminate/support": "^12.0|^13.0",
    "spatie/laravel-glide": "^3.6"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0|^11.0",
    "phpunit/phpunit": "^11.5|^12.5"
  },
  "extra": {
    "laravel": {
      "providers": [
        "MacCesar\\LaravelGlideEnhanced\\ImageProcessorServiceProvider"
      ],
      "aliases": {
        "ImageProcessor": "MacCesar\\LaravelGlideEnhanced\\Facades\\ImageProcessor"
      }
    }
  }
}
